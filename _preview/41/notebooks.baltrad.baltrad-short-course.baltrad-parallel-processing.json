mn":1},"end":{"line":36,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"retrieve data from s3 bucket","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"saJZrR6xmt"}],"identifier":"retrieve-data-from-s3-bucket","label":"retrieve data from s3 bucket","html_id":"retrieve-data-from-s3-bucket","implicit":true,"key":"sPVkieCNdh"}],"key":"tt6yCwCPan"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport urllib.request\nfrom pathlib import Path\n\n# Set the URL for the cloud\nURL = \"https://js2.jetstream-cloud.org:8001/\"\npath = \"pythia/radar/erad2024/baltrad/baltrad_short_course/\"\n!mkdir -p data\nfiles = [\n    \"seang.h5\",\n    \"searl.h5\",\n    \"sease.h5\",\n    \"sehud.h5\",\n    \"sekir.h5\",\n    \"sekkr.h5\",\n    \"selek.h5\",\n    \"selul.h5\",\n    \"seosu.h5\",\n    \"sevar.h5\",\n    \"sevil.h5\",\n]\nfor file in files:\n    file0 = os.path.join(path, file)\n    name = os.path.join(\"data\", Path(file).name)\n    if not os.path.exists(name):\n        print(f\"downloading, {name}\")\n        urllib.request.urlretrieve(\n            f\"{URL}{file0}\", os.path.join(\"data\", Path(file).name)\n        )","key":"iGCLTVHv9X"},{"type":"outputs","id":"-w3rzdcJZRkUn6ZP7J-LJ","children":[],"key":"C2bFIk1vAT"}],"key":"QdzyhrCdaP"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Verify from Python the number of CPU cores at our disposal","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"EY1LWG6WXT"}],"identifier":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","label":"Verify from Python the number of CPU cores at our disposal","html_id":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","implicit":true,"key":"tBVuz7wqAK"}],"key":"bYQbtym6b2"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import multiprocessing\n\nprint(\"We have %i cores to play with!\" % multiprocessing.cpu_count())","key":"QLWFjDc500"},{"type":"outputs","id":"1FW1oZoMwUbkfax0oEiP5","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"We have 4 cores to play with!\n"},"key":"nZ38odDiNH"}],"key":"zhMVmDntZN"}],"key":"OD4NO8u7DC"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Yay! Now we’re going to set up some rudimentary functionality that will allow us to distribute a processing load among our cores.","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"dIvr5RffE4"}],"key":"j5deVDauSo"}],"key":"xj9hnVv3sl"},{"type":"block","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"Define a generator","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"nKsF4kUeSt"}],"identifier":"define-a-generator","label":"Define a generator","html_id":"define-a-generator","implicit":true,"key":"kN14TdZaka"}],"key":"OI4L0OjCCv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport _raveio, odc_polarQC\n\n# Specify the processing chain\nodc_polarQC.algorithm_ids = [\n    \"ropo\",\n    \"beamb\",\n    \"radvol-att\",\n    \"radvol-broad\",\n    \"rave-overshooting\",\n    \"qi-total\",\n]\n\n\n# Run processing chain on a single file. Return an output file string.\ndef generate(file_string):\n    rio = _raveio.open(file_string)\n\n    pvol = rio.object\n    pvol = odc_polarQC.QC(pvol)\n    rio.object = pvol\n\n    # Derive an output file name\n    path, fstr = os.path.split(file_string)\n    ofstr = os.path.join(path, \"qc_\" + fstr)\n\n    rio.save(ofstr)\n    return ofstr","key":"ItGfOiXWXb"},{"type":"outputs","id":"tZXS3ow-fSPfQKcQWmXdY","children":[],"key":"wJ3of6QyM2"}],"key":"eRTZXScqMh"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Feed the generator, sequentially","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"ZKyxvurAnG"}],"identifier":"feed-the-generator-sequentially","label":"Feed the generator, sequentially","html_id":"feed-the-generator-sequentially","implicit":true,"key":"MoIeNvE0Vr"}],"key":"cTK6KXSUMd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import glob, time\n\nifstrs = glob.glob(\"data/se*.h5\")\nbefore = time.time()\nfor fstr in ifstrs:\n    print(fstr, generate(fstr))\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"MRBMit14FK"},{"type":"outputs","id":"9WiU1HQUcgGvkhzj32jGu","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selul.h5 data/qc_selul.h5\n"},"key":"du8V8dqBpq"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/searl.h5 data/qc_searl.h5\n"},"key":"QdYC1xoWTz"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevil.h5 data/qc_sevil.h5\n"},"key":"d64YDc5g4w"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekir.h5 data/qc_sekir.h5\n"},"key":"C6AZ8rDndD"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sease.h5 data/qc_sease.h5\n"},"key":"By2BTr7GCY"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekkr.h5 data/qc_sekkr.h5\n"},"key":"OQoFoVwjJu"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selek.h5 data/qc_selek.h5\n"},"key":"CRhp324GX3"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seang.h5 data/qc_seang.h5\n"},"key":"kfDW1Cfvwf"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sehud.h5 data/qc_sehud.h5\n"},"key":"w0uer5yWSN"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevar.h5 data/qc_sevar.h5\n"},"key":"Ov0AXNyFI3"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seosu.h5 data/qc_seosu.h5\nProcessing time: 5.54 seconds\n"},"key":"KTSMyPrLRP"}],"key":"dFw2BWCnOa"}],"key":"uhzZqWtWh1"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"text","value":"Mental note: repeat once!","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"key":"NrYp9v9ubz"}],"key":"fshPtyvTxC"}],"key":"EIWqfQprbG"},{"type":"block","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"Multiprocess the generator","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"key":"JhQRpkdXoQ"}],"identifier":"multiprocess-the-generator","label":"Multiprocess the generator","html_id":"multiprocess-the-generator","implicit":true,"key":"PZSx2o15eh"}],"key":"MwLyF3xpi8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Both input and output are a list of file strings\ndef multi_generate(fstrs, procs=None):\n    pool = multiprocessing.Pool(\n        procs\n    )  # Pool of processors. Defaults to all available logical cores\n\n    results = []\n    # chunksize=1 means feed a process a new job as soon as the process is idle.\n    # In our case, this restricts the queue to one \"dispatcher\" which is faster.\n    r = pool.map_async(generate, fstrs, chunksize=1, callback=results.append)\n    r.wait()\n\n    return results[0]","key":"xEMjkjZPqQ"},{"type":"outputs","id":"wYfQWsyWur6nbbcyZN2B7","children":[],"key":"ilZLlhBIP5"}],"key":"VslPCR8mtL"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"Feed the monster, asynchronously!","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"key":"MAMvfJSwPN"}],"identifier":"feed-the-monster-asynchronously","label":"Feed the monster, asynchronously!","html_id":"feed-the-monster-asynchronously","implicit":true,"key":"KgjKYgYMCX"}],"key":"Lqdu24X53m"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"before = time.time()\nofstrs = multi_generate(ifstrs)\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"NSiZn2MwPT"},{"type":"outputs","id":"j61BAd5VzRMaAGcVanhl_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Processing time: 2.46 seconds\n"},"key":"Y2Oq977zhM"}],"key":"op27A28faX"}],"key":"O5YIfdBMhn"},{"type":"block","children":[],"key":"n48q4BcAdB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"jYY2H6LAhI"},{"type":"outputs","id":"w_AiSa-CRTIt6NoT8qh_E","children":[],"key":"z0WtC47zPn"}],"key":"ro2FH1wyJO"}],"key":"veO4YOo91O"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Quality Control using DR","url":"/notebooks/baltrad/baltrad-short-cou