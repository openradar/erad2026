ket","implicit":true,"key":"Gd4DFFg9HH"}],"key":"x1qJJqI4vD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport urllib.request\nfrom pathlib import Path\n\n# Set the URL for the cloud\nURL = \"https://js2.jetstream-cloud.org:8001/\"\npath = \"pythia/radar/erad2024/baltrad/baltrad_short_course/\"\n!mkdir -p data\nfiles = [\n    \"seang.h5\",\n    \"searl.h5\",\n    \"sease.h5\",\n    \"sehud.h5\",\n    \"sekir.h5\",\n    \"sekkr.h5\",\n    \"selek.h5\",\n    \"selul.h5\",\n    \"seosu.h5\",\n    \"sevar.h5\",\n    \"sevil.h5\",\n]\nfor file in files:\n    file0 = os.path.join(path, file)\n    name = os.path.join(\"data\", Path(file).name)\n    if not os.path.exists(name):\n        print(f\"downloading, {name}\")\n        urllib.request.urlretrieve(\n            f\"{URL}{file0}\", os.path.join(\"data\", Path(file).name)\n        )","key":"mhmHKhgv3T"},{"type":"outputs","id":"QNJ3ymlfT-XFJhiQIaIpn","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/seang.h5\n"},"key":"p8jSVFAgNG"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/searl.h5\n"},"key":"gonaU3xtd3"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/sease.h5\ndownloading, data/sehud.h5\n"},"key":"ai5iQC1f88"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/sekir.h5\n"},"key":"B3m9cYGWd6"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/sekkr.h5\n"},"key":"aWfzeDUsIx"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/selek.h5\ndownloading, data/selul.h5\n"},"key":"SwuhogyNuH"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/seosu.h5\ndownloading, data/sevar.h5\n"},"key":"fFNnbZVDSy"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/sevil.h5\n"},"key":"MFuRBQqj5U"}],"key":"obrIuOcGrl"}],"key":"VFstl9F9vv"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Verify from Python the number of CPU cores at our disposal","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"h6vZ5JdKfu"}],"identifier":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","label":"Verify from Python the number of CPU cores at our disposal","html_id":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","implicit":true,"key":"L3HzRCXtoG"}],"key":"kU2mfcWltf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import multiprocessing\n\nprint(\"We have %i cores to play with!\" % multiprocessing.cpu_count())","key":"ifASLm8UTj"},{"type":"outputs","id":"s7q_XLDPSrpyWD7whlV5D","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"We have 4 cores to play with!\n"},"key":"BhCfsMZXJV"}],"key":"rFxGj8Pa3x"}],"key":"mUjs96EtPJ"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Yay! Now we’re going to set up some rudimentary functionality that will allow us to distribute a processing load among our cores.","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"kYMXlQFDgS"}],"key":"hu9ykBZSmt"}],"key":"u5DDCPiNBP"},{"type":"block","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"Define a generator","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"Jyaxh6Un0T"}],"identifier":"define-a-generator","label":"Define a generator","html_id":"define-a-generator","implicit":true,"key":"RHwmQ93ogr"}],"key":"wfp7sRljRZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport _raveio, odc_polarQC\n\n# Specify the processing chain\nodc_polarQC.algorithm_ids = [\n    \"ropo\",\n    \"beamb\",\n    \"radvol-att\",\n    \"radvol-broad\",\n    \"rave-overshooting\",\n    \"qi-total\",\n]\n\n\n# Run processing chain on a single file. Return an output file string.\ndef generate(file_string):\n    rio = _raveio.open(file_string)\n\n    pvol = rio.object\n    pvol = odc_polarQC.QC(pvol)\n    rio.object = pvol\n\n    # Derive an output file name\n    path, fstr = os.path.split(file_string)\n    ofstr = os.path.join(path, \"qc_\" + fstr)\n\n    rio.save(ofstr)\n    return ofstr","key":"Y7D0pgpW9t"},{"type":"outputs","id":"IsSe2Ke4s_iD_9XfA7fuX","children":[],"key":"Diai6q8aQG"}],"key":"V2tXb0dDFo"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Feed the generator, sequentially","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"lhdoAt6hzC"}],"identifier":"feed-the-generator-sequentially","label":"Feed the generator, sequentially","html_id":"feed-the-generator-sequentially","implicit":true,"key":"edD4cvMVYH"}],"key":"XJYSLU6m19"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import glob, time\n\nifstrs = glob.glob(\"data/se*.h5\")\nbefore = time.time()\nfor fstr in ifstrs:\n    print(fstr, generate(fstr))\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"OFQqA734QG"},{"type":"outputs","id":"STNZsupfKkzn2D_pMDiYt","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevar.h5 data/qc_sevar.h5\n"},"key":"axGidAV9JA"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sehud.h5 data/qc_sehud.h5\n"},"key":"bgWKw7gVFF"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sease.h5 data/qc_sease.h5\n"},"key":"fbEK9UFsmp"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seang.h5 data/qc_seang.h5\n"},"key":"wj12U8UED0"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekkr.h5 data/qc_sekkr.h5\n"},"key":"aOI8VX9G95"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekir.h5 data/qc_sekir.h5\n"},"key":"DxGbztJnaF"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seosu.h5 data/qc_seosu.h5\n"},"key":"bjsKslwajU"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/searl.h5 data/qc_searl.h5\n"},"key":"Cj98r9sLVc"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selek.h5 data/qc_selek.h5\n"},"key":"IH7byUXN6a"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selul.h5 data/qc_selul.h5\n"},"key":"EyORN3TLSO"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevil.h5 data/qc_sevil.h5\nProcessing time: 52.18 seconds\n"},"key":"EanJr3XNAE"}],"key":"YFDS0st2tz"}],"key":"uPq4M3U62O"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"text","value":"Mental note: repeat once!","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"key":"OlDQVdBOfh"}],"key":"T2aH8kyjxn"}],"key":"kxohGoAYxv"},{"type":"block","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"Multiprocess the generator","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"key":"vF8hpoC7Vj"}],"identifier":"multiprocess-the-generator","label":"Multiprocess the generator","html_id":"multiprocess-the-generator","implicit":true,"key":"YspL9dbCNk"}],"key":"sJ0hqWqV5I"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Both input and output are a list of file strings\ndef multi_generate(fstrs, procs=None):\n    pool = multiprocessing.Pool(\n        procs\n    )  # Pool of processors. Defaults to all available logical cores\n\n    results = []\n    # chunksize=1 means feed a process a new job as soon as the process is idle.\n    # In our case, this restricts the queue to one \"dispatcher\" which is faster.\n    r = pool.map_async(generate, fstrs, chunksize=1, callback=results.append)\n    r.wait()\n\n    return results[0]","key":"NxQO6phbir"},{"type":"outputs","id":"8UaSh-PLwn4LzNHhYp6Gm","children":[],"key":"v2rF00ierG"}],"key":"XsJKIfPX9q"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"Feed the monster, asynchronously!","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"key":"zeyqZIyGjG"}],"identifier":"feed-the-monster-asynchronously","label":"Feed the monster, asynchronously!","html_id":"feed-the-monster-asynchronously","implicit":true,"key":"q3YS3n0qc9"}],"key":"yNP55Ngli5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"before = time.time()\nofstrs = multi_generate(ifstrs)\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"baBGBynuMj"},{"type":"outputs","id":"oddAihBMZ9MdspNUpMqIh","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Processing time: 2.44 seconds\n"},"key":"nNSAHAq6CK"}],"key":"MLAZdss2I3"}],"key":"paZhvuCp8N"},{"type":"block","children":[],"key":"pBMW6PpQ0Q"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"LQUNgkIsoz"},{"type":"outputs","id":"rHczys9ltGpVUrZ9z0ACL","children":[],"key":"wujXFl52C4"}],"key":"H0E23hKCv3"}],"key":"XugGdnMtPE"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Quality Control using DR","url":"/notebooks/baltrad/baltrad-short-course/baltrad-drqc","group":"BALTRAD"},"next":{"title":"Compositing","url":"/notebooks/baltrad/baltrad-short-course/baltrad-compositing","group":"BALTRAD"}}},"domain":"http://localhost:3000"}