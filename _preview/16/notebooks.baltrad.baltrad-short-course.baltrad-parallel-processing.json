ket","implicit":true,"key":"ZHwsJV2UXg"}],"key":"Zcuv7nWqco"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport urllib.request\nfrom pathlib import Path\n\n# Set the URL for the cloud\nURL = \"https://js2.jetstream-cloud.org:8001/\"\npath = \"pythia/radar/erad2024/baltrad/baltrad_short_course/\"\n!mkdir -p data\nfiles = [\n    \"seang.h5\",\n    \"searl.h5\",\n    \"sease.h5\",\n    \"sehud.h5\",\n    \"sekir.h5\",\n    \"sekkr.h5\",\n    \"selek.h5\",\n    \"selul.h5\",\n    \"seosu.h5\",\n    \"sevar.h5\",\n    \"sevil.h5\",\n]\nfor file in files:\n    file0 = os.path.join(path, file)\n    name = os.path.join(\"data\", Path(file).name)\n    if not os.path.exists(name):\n        print(f\"downloading, {name}\")\n        urllib.request.urlretrieve(\n            f\"{URL}{file0}\", os.path.join(\"data\", Path(file).name)\n        )","key":"kIilV9u79c"},{"type":"outputs","id":"RagFZVrS8rdIgMZ0F7cqF","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/seang.h5\n"},"key":"rlU1iCyOlo"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/searl.h5\ndownloading, data/sease.h5\n"},"key":"fa4j3foOsd"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/sehud.h5\n"},"key":"D7tJWSjNbR"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/sekir.h5\ndownloading, data/sekkr.h5\n"},"key":"ACWVOdnxDU"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/selek.h5\n"},"key":"QXGa4ABnm5"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/selul.h5\n"},"key":"LoNP1Joznw"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/seosu.h5\ndownloading, data/sevar.h5\n"},"key":"Hy2QbIocVQ"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"downloading, data/sevil.h5\n"},"key":"nS038XSxCV"}],"key":"Emdm5mSkP1"}],"key":"ltgeKxlnFG"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Verify from Python the number of CPU cores at our disposal","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"XCYjtCjvd6"}],"identifier":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","label":"Verify from Python the number of CPU cores at our disposal","html_id":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","implicit":true,"key":"QfGh0ess0D"}],"key":"qYrPuak4p6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import multiprocessing\n\nprint(\"We have %i cores to play with!\" % multiprocessing.cpu_count())","key":"E5iUgtdQTQ"},{"type":"outputs","id":"l_gtyMGZXaPKzfNi84D8q","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"We have 4 cores to play with!\n"},"key":"Uf1KkiY8CF"}],"key":"zRmHrIyczL"}],"key":"A511Xz82v9"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Yay! Now we’re going to set up some rudimentary functionality that will allow us to distribute a processing load among our cores.","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"OsZ9DeodKW"}],"key":"NIdDUslPtZ"}],"key":"VRN20bakxq"},{"type":"block","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"Define a generator","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"OTiFLHa5Zv"}],"identifier":"define-a-generator","label":"Define a generator","html_id":"define-a-generator","implicit":true,"key":"lID0jCSede"}],"key":"RaLfFf9W5m"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport _raveio, odc_polarQC\n\n# Specify the processing chain\nodc_polarQC.algorithm_ids = [\n    \"ropo\",\n    \"beamb\",\n    \"radvol-att\",\n    \"radvol-broad\",\n    \"rave-overshooting\",\n    \"qi-total\",\n]\n\n\n# Run processing chain on a single file. Return an output file string.\ndef generate(file_string):\n    rio = _raveio.open(file_string)\n\n    pvol = rio.object\n    pvol = odc_polarQC.QC(pvol)\n    rio.object = pvol\n\n    # Derive an output file name\n    path, fstr = os.path.split(file_string)\n    ofstr = os.path.join(path, \"qc_\" + fstr)\n\n    rio.save(ofstr)\n    return ofstr","key":"hWHf8SzDNG"},{"type":"outputs","id":"-uJM-fVGEhyQJWjHGm37Y","children":[],"key":"jb8OVxRSr1"}],"key":"i2slK0uJt7"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Feed the generator, sequentially","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"BxkoLIURv6"}],"identifier":"feed-the-generator-sequentially","label":"Feed the generator, sequentially","html_id":"feed-the-generator-sequentially","implicit":true,"key":"vLsUVjKA6K"}],"key":"i1r9KrkH0G"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import glob, time\n\nifstrs = glob.glob(\"data/se*.h5\")\nbefore = time.time()\nfor fstr in ifstrs:\n    print(fstr, generate(fstr))\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"hncpc1mmcO"},{"type":"outputs","id":"ANzAQW8jj5Itr63kga5An","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevar.h5 data/qc_sevar.h5\n"},"key":"i4ythmCxFl"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sehud.h5 data/qc_sehud.h5\n"},"key":"gY06u1pplh"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sease.h5 data/qc_sease.h5\n"},"key":"zqNPJBc89X"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seang.h5 data/qc_seang.h5\n"},"key":"Owosb6GngA"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekkr.h5 data/qc_sekkr.h5\n"},"key":"jEiWXfHFVG"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekir.h5 data/qc_sekir.h5\n"},"key":"pgrd62H1sO"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seosu.h5 data/qc_seosu.h5\n"},"key":"Uj50FiCYBg"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/searl.h5 data/qc_searl.h5\n"},"key":"RdQdSKqOEx"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selek.h5 data/qc_selek.h5\n"},"key":"yK4yZuMMP5"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selul.h5 data/qc_selul.h5\n"},"key":"WX1VNpRsXw"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevil.h5 data/qc_sevil.h5\nProcessing time: 50.24 seconds\n"},"key":"XJnxwIKa81"}],"key":"Q8hngX3ZaG"}],"key":"Lo5KIToEGG"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"text","value":"Mental note: repeat once!","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"key":"rTVr7Za6Td"}],"key":"S8qhd3pR9n"}],"key":"hKscYZvycj"},{"type":"block","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"Multiprocess the generator","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"key":"uznSJmb7CR"}],"identifier":"multiprocess-the-generator","label":"Multiprocess the generator","html_id":"multiprocess-the-generator","implicit":true,"key":"ONEhRb19FM"}],"key":"cqmvIv1OZ0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Both input and output are a list of file strings\ndef multi_generate(fstrs, procs=None):\n    pool = multiprocessing.Pool(\n        procs\n    )  # Pool of processors. Defaults to all available logical cores\n\n    results = []\n    # chunksize=1 means feed a process a new job as soon as the process is idle.\n    # In our case, this restricts the queue to one \"dispatcher\" which is faster.\n    r = pool.map_async(generate, fstrs, chunksize=1, callback=results.append)\n    r.wait()\n\n    return results[0]","key":"QoMNslWab7"},{"type":"outputs","id":"9gUuunn6kuIXljHXL2Veb","children":[],"key":"KDhJf17fUJ"}],"key":"W6Al0to8LD"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"Feed the monster, asynchronously!","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"key":"Q4L4EKI1mQ"}],"identifier":"feed-the-monster-asynchronously","label":"Feed the monster, asynchronously!","html_id":"feed-the-monster-asynchronously","implicit":true,"key":"mAwK1s0zPs"}],"key":"Fj46xVUg6a"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"before = time.time()\nofstrs = multi_generate(ifstrs)\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"SkbPHWWqhE"},{"type":"outputs","id":"Ejzr24NOQzgdurXNcr-oj","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Processing time: 2.47 seconds\n"},"key":"UJIaVIh9mV"}],"key":"T31EWm1S3V"}],"key":"dU1Owm6uzR"},{"type":"block","children":[],"key":"lgeOkr2THB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"D6OHGUsMzE"},{"type":"outputs","id":"9vZ6cwwmzUgyqkZxsru8H","children":[],"key":"jjMmH3BrnV"}],"key":"Krt7UgZUrq"}],"key":"Qyh6VNw2Cs"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Quality Control using DR","url":"/notebooks/baltrad/baltrad-short-course/baltrad-drqc","group":"BALTRAD"},"next":{"title":"Compositing","url":"/notebooks/baltrad/baltrad-short-course/baltrad-compositing","group":"BALTRAD"}}},"domain":"http://localhost:3000"}