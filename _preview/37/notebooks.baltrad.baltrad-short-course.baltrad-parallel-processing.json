mn":1},"end":{"line":36,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"retrieve data from s3 bucket","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"mhiES09iKk"}],"identifier":"retrieve-data-from-s3-bucket","label":"retrieve data from s3 bucket","html_id":"retrieve-data-from-s3-bucket","implicit":true,"key":"wZQaCf2uXq"}],"key":"nxRtq3Gua4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport urllib.request\nfrom pathlib import Path\n\n# Set the URL for the cloud\nURL = \"https://js2.jetstream-cloud.org:8001/\"\npath = \"pythia/radar/erad2024/baltrad/baltrad_short_course/\"\n!mkdir -p data\nfiles = [\n    \"seang.h5\",\n    \"searl.h5\",\n    \"sease.h5\",\n    \"sehud.h5\",\n    \"sekir.h5\",\n    \"sekkr.h5\",\n    \"selek.h5\",\n    \"selul.h5\",\n    \"seosu.h5\",\n    \"sevar.h5\",\n    \"sevil.h5\",\n]\nfor file in files:\n    file0 = os.path.join(path, file)\n    name = os.path.join(\"data\", Path(file).name)\n    if not os.path.exists(name):\n        print(f\"downloading, {name}\")\n        urllib.request.urlretrieve(\n            f\"{URL}{file0}\", os.path.join(\"data\", Path(file).name)\n        )","key":"S29ipeq38z"},{"type":"outputs","id":"MJw2_Pg2D8O8wctGD592_","children":[],"key":"wEJORnvVZI"}],"key":"PA4PP48wMl"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Verify from Python the number of CPU cores at our disposal","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"aDKSsKEpQ9"}],"identifier":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","label":"Verify from Python the number of CPU cores at our disposal","html_id":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","implicit":true,"key":"NL7GFXfdYX"}],"key":"n4KKEqIPy9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import multiprocessing\n\nprint(\"We have %i cores to play with!\" % multiprocessing.cpu_count())","key":"IMzWkWwRqv"},{"type":"outputs","id":"D39mFIJsGPLsxqbV5cyfy","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"We have 4 cores to play with!\n"},"key":"kTa35I6pxc"}],"key":"dPA2zJ0QDY"}],"key":"rYfeKZq9Uw"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Yay! Now we’re going to set up some rudimentary functionality that will allow us to distribute a processing load among our cores.","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"ko7tC1Zb38"}],"key":"Vx6LcryMll"}],"key":"Fw2UR859cQ"},{"type":"block","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"Define a generator","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"WVtQGGA6KN"}],"identifier":"define-a-generator","label":"Define a generator","html_id":"define-a-generator","implicit":true,"key":"qxvj4FScMm"}],"key":"ZzG3ROh7Su"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport _raveio, odc_polarQC\n\n# Specify the processing chain\nodc_polarQC.algorithm_ids = [\n    \"ropo\",\n    \"beamb\",\n    \"radvol-att\",\n    \"radvol-broad\",\n    \"rave-overshooting\",\n    \"qi-total\",\n]\n\n\n# Run processing chain on a single file. Return an output file string.\ndef generate(file_string):\n    rio = _raveio.open(file_string)\n\n    pvol = rio.object\n    pvol = odc_polarQC.QC(pvol)\n    rio.object = pvol\n\n    # Derive an output file name\n    path, fstr = os.path.split(file_string)\n    ofstr = os.path.join(path, \"qc_\" + fstr)\n\n    rio.save(ofstr)\n    return ofstr","key":"t6rsiLV0OS"},{"type":"outputs","id":"VfHojCajY-v2Weqz6fo1G","children":[],"key":"jwNlyYm47F"}],"key":"HKax1UIdHI"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Feed the generator, sequentially","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"gc72b6tiJY"}],"identifier":"feed-the-generator-sequentially","label":"Feed the generator, sequentially","html_id":"feed-the-generator-sequentially","implicit":true,"key":"rEcjEnm1OJ"}],"key":"bJY9H54px7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import glob, time\n\nifstrs = glob.glob(\"data/se*.h5\")\nbefore = time.time()\nfor fstr in ifstrs:\n    print(fstr, generate(fstr))\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"IU8J3RsUsi"},{"type":"outputs","id":"dE4XqrzQmdHR0mwQnjjYw","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/searl.h5 data/qc_searl.h5\n"},"key":"hqzIJq6uJW"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selek.h5 data/qc_selek.h5\n"},"key":"W18M10GMUm"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekkr.h5 data/qc_sekkr.h5\n"},"key":"HqmH99XMv9"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seang.h5 data/qc_seang.h5\n"},"key":"j8T1taVx5N"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seosu.h5 data/qc_seosu.h5\n"},"key":"PZTIKXEEgi"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selul.h5 data/qc_selul.h5\n"},"key":"PifnVfzm5a"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevar.h5 data/qc_sevar.h5\n"},"key":"o4DNOJht48"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevil.h5 data/qc_sevil.h5\n"},"key":"QSCFJtotxX"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sehud.h5 data/qc_sehud.h5\n"},"key":"Flh0aR8x9g"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekir.h5 data/qc_sekir.h5\n"},"key":"aKJ2YyyJJc"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sease.h5 data/qc_sease.h5\nProcessing time: 5.36 seconds\n"},"key":"jaOhJmg8lG"}],"key":"jWOH0G9cwz"}],"key":"n6QPms3djl"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"text","value":"Mental note: repeat once!","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"key":"sE6kuSIfli"}],"key":"n0wyOh9jJv"}],"key":"AnM5nBENtJ"},{"type":"block","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"Multiprocess the generator","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"key":"mB1KkR9MLo"}],"identifier":"multiprocess-the-generator","label":"Multiprocess the generator","html_id":"multiprocess-the-generator","implicit":true,"key":"WT93jeKdIF"}],"key":"sNTb93E8MH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Both input and output are a list of file strings\ndef multi_generate(fstrs, procs=None):\n    pool = multiprocessing.Pool(\n        procs\n    )  # Pool of processors. Defaults to all available logical cores\n\n    results = []\n    # chunksize=1 means feed a process a new job as soon as the process is idle.\n    # In our case, this restricts the queue to one \"dispatcher\" which is faster.\n    r = pool.map_async(generate, fstrs, chunksize=1, callback=results.append)\n    r.wait()\n\n    return results[0]","key":"TP4kE4lb2Z"},{"type":"outputs","id":"NkhIKFZavT_DOGzAuRtkA","children":[],"key":"V2XpZMhAys"}],"key":"decSLcFXbg"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"Feed the monster, asynchronously!","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"key":"IoPceeFUpj"}],"identifier":"feed-the-monster-asynchronously","label":"Feed the monster, asynchronously!","html_id":"feed-the-monster-asynchronously","implicit":true,"key":"hKs8Wu4HqB"}],"key":"zmefph83pT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"before = time.time()\nofstrs = multi_generate(ifstrs)\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"sXhMgEJe3l"},{"type":"outputs","id":"EETGSVEEPKpQ_3wUMqjD9","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Processing time: 2.44 seconds\n"},"key":"fsUYQfvk2L"}],"key":"EwNRF6qTFX"}],"key":"rpQu5i3HAh"},{"type":"block","children":[],"key":"hrDYHEJPj8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"fSrLvBdyJ2"},{"type":"outputs","id":"iquz5yh0e-n68bI8Z0bB9","children":[],"key":"O8aAPMyqaE"}],"key":"fxi4XxTt1Q"}],"key":"oyXRFnknRg"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Quality Control using DR","url":"/notebooks/baltrad/baltrad-short-cou