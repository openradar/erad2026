e\n        else matplotlib.colors.ListedColormap(colorlist)\n    )\n    plt.imshow(data, cmap=clist, clim=(0, 255))\n    plt.colorbar(shrink=float(data.shape[mini]) / data.shape[maxi])","key":"QTQ9qMapTd"},{"type":"outputs","id":"2yb6DTcdQKRQ2fgAiIknJ","children":[],"key":"mdPOQvLESE"}],"key":"BEmZxRcYUd"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"children":[{"type":"text","value":"Access the polar volume and plot VRAD data from the lowest scan","position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"key":"KWCRSCGC47"}],"identifier":"access-the-polar-volume-and-plot-vrad-data-from-the-lowest-scan","label":"Access the polar volume and plot VRAD data from the lowest scan","html_id":"access-the-polar-volume-and-plot-vrad-data-from-the-lowest-scan","implicit":true,"key":"DIcoOvJROq"}],"key":"RbkuFbS02S"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pvol = rio.object\nplot(pvol.getScan(0).getParameter(\"VRADH\").getData(), vradcl, \"Original VRAD\")","key":"ea6ebXfqs7"},{"type":"outputs","id":"jB_LKw37scqgVd_m5G2T-","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1600x1200 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"e2bebe4d36082ae134497507fcf92369","path":"/erad2026/_preview/17//build/e2bebe4d36082ae134497507fcf92369.png"}}},"key":"sQB10765TU"}],"key":"MGUg0ktaim"}],"key":"Q4fVTvKiy9"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"children":[{"type":"text","value":"Dealias the volume","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"key":"d4G946tu5M"}],"identifier":"dealias-the-volume","label":"Dealias the volume","html_id":"dealias-the-volume","im