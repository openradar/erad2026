{"line":36,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"retrieve data from s3 bucket","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"NSEHS3NdEH"}],"identifier":"retrieve-data-from-s3-bucket","label":"retrieve data from s3 bucket","html_id":"retrieve-data-from-s3-bucket","implicit":true,"key":"SgeEWs6hiy"}],"key":"jm0HM8hyis"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport urllib.request\nfrom pathlib import Path\n\n# Set the URL for the cloud\nURL = \"https://js2.jetstream-cloud.org:8001/\"\npath = \"pythia/radar/erad2024/baltrad/baltrad_short_course/\"\n!mkdir -p data\nfiles = [\n    \"seang.h5\",\n    \"searl.h5\",\n    \"sease.h5\",\n    \"sehud.h5\",\n    \"sekir.h5\",\n    \"sekkr.h5\",\n    \"selek.h5\",\n    \"selul.h5\",\n    \"seosu.h5\",\n    \"sevar.h5\",\n    \"sevil.h5\",\n]\nfor file in files:\n    file0 = os.path.join(path, file)\n    name = os.path.join(\"data\", Path(file).name)\n    if not os.path.exists(name):\n        print(f\"downloading, {name}\")\n        urllib.request.urlretrieve(\n            f\"{URL}{file0}\", os.path.join(\"data\", Path(file).name)\n        )","key":"uxsbM48F2A"},{"type":"outputs","id":"LqXdkfA0gX0Kbta-8tTG2","children":[],"key":"v2wfvkQPs0"}],"key":"woimfsRFK0"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Verify from Python the number of CPU cores at our disposal","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"GUppW17N4N"}],"identifier":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","label":"Verify from Python the number of CPU cores at our disposal","html_id":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","implicit":true,"key":"ZhbuBJED4g"}],"key":"jLnRXGdV96"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import multiprocessing\n\nprint(\"We have %i cores to play with!\" % multiprocessing.cpu_count())","key":"uworYnCWFd"},{"type":"outputs","id":"6tDRp4d0RzffoeQraSw7F","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"We have 4 cores to play with!\n"},"key":"lsA0xFLVLi"}],"key":"PkuLOVIRBv"}],"key":"LMkqU7GpKy"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Yay! Now we’re going to set up some rudimentary functionality that will allow us to distribute a processing load among our cores.","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"ScMUguab99"}],"key":"VUxW3CSDpR"}],"key":"qRrR23XZf1"},{"type":"block","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"Define a generator","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"aiRuprJdSA"}],"identifier":"define-a-generator","label":"Define a generator","html_id":"define-a-generator","implicit":true,"key":"yfYBtsW4HG"}],"key":"fkiib1Fy83"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport _raveio, odc_polarQC\n\n# Specify the processing chain\nodc_polarQC.algorithm_ids = [\n    \"ropo\",\n    \"beamb\",\n    \"radvol-att\",\n    \"radvol-broad\",\n    \"rave-overshooting\",\n    \"qi-total\",\n]\n\n\n# Run processing chain on a single file. Return an output file string.\ndef generate(file_string):\n    rio = _raveio.open(file_string)\n\n    pvol = rio.object\n    pvol = odc_polarQC.QC(pvol)\n    rio.object = pvol\n\n    # Derive an output file name\n    path, fstr = os.path.split(file_string)\n    ofstr = os.path.join(path, \"qc_\" + fstr)\n\n    rio.save(ofstr)\n    return ofstr","key":"QvtOL53QV8"},{"type":"outputs","id":"MYZHO15EnCMLBPcQCsEJi","children":[],"key":"g5JHpyWzee"}],"key":"XRXc203yij"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Feed the generator, sequentially","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"scxBMEHIl7"}],"identifier":"feed-the-generator-sequentially","label":"Feed the generator, sequentially","html_id":"feed-the-generator-sequentially","implicit":true,"key":"uW5FyoSo3f"}],"key":"IaeQKmsVkv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import glob, time\n\nifstrs = glob.glob(\"data/se*.h5\")\nbefore = time.time()\nfor fstr in ifstrs:\n    print(fstr, generate(fstr))\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"uRREAISgHx"},{"type":"outputs","id":"gnRLHwdZvAOazl63_ogij","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selul.h5 data/qc_selul.h5\n"},"key":"WLe1Xm6Onk"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/searl.h5 data/qc_searl.h5\n"},"key":"WydaT5f1KN"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevil.h5 data/qc_sevil.h5\n"},"key":"WvbST8SK1A"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekir.h5 data/qc_sekir.h5\n"},"key":"f1gTJi99n5"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sease.h5 data/qc_sease.h5\n"},"key":"quNPpPrQke"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekkr.h5 data/qc_sekkr.h5\n"},"key":"fq0sUaeAeZ"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selek.h5 data/qc_selek.h5\n"},"key":"PPwhkkbAbZ"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seang.h5 data/qc_seang.h5\n"},"key":"HjhBZC4qUp"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sehud.h5 data/qc_sehud.h5\n"},"key":"M6flk8eUxy"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevar.h5 data/qc_sevar.h5\n"},"key":"ijhjGjYbeK"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seosu.h5 data/qc_seosu.h5\nProcessing time: 5.15 seconds\n"},"key":"vp0l1MHygn"}],"key":"fLq7MHioUo"}],"key":"cHkTbhHGKH"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"text","value":"Mental note: repeat once!","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"key":"yD8yII1X5I"}],"key":"I5Wee76Aum"}],"key":"mAutWYtTFP"},{"type":"block","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"Multiprocess the generator","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"key":"DM1V1T8P0S"}],"identifier":"multiprocess-the-generator","label":"Multiprocess the generator","html_id":"multiprocess-the-generator","implicit":true,"key":"Ts6SYMMTPy"}],"key":"CAkVAKiyZ6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Both input and output are a list of file strings\ndef multi_generate(fstrs, procs=None):\n    pool = multiprocessing.Pool(\n        procs\n    )  # Pool of processors. Defaults to all available logical cores\n\n    results = []\n    # chunksize=1 means feed a process a new job as soon as the process is idle.\n    # In our case, this restricts the queue to one \"dispatcher\" which is faster.\n    r = pool.map_async(generate, fstrs, chunksize=1, callback=results.append)\n    r.wait()\n\n    return results[0]","key":"TsCqfRy3jK"},{"type":"outputs","id":"OblYgRcKmYI2wwncewnhq","children":[],"key":"n4mgYkC5Lg"}],"key":"qxEjYlR5C8"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"Feed the monster, asynchronously!","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"key":"hhbvmh8wLu"}],"identifier":"feed-the-monster-asynchronously","label":"Feed the monster, asynchronously!","html_id":"feed-the-monster-asynchronously","implicit":true,"key":"rDEC8GPP5e"}],"key":"GqRLJnNfOB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"before = time.time()\nofstrs = multi_generate(ifstrs)\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"kfem0yl9Ay"},{"type":"outputs","id":"EpzJkNJXdCWg29gzMouhD","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Processing time: 2.04 seconds\n"},"key":"gNnpLnaNqz"}],"key":"jqahIDKlbO"}],"key":"ruiSdyOkxH"},{"type":"block","children":[],"key":"UkyPF34MxB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"tp5BDExJD5"},{"type":"outputs","id":"mto5Pjf32Ef2N4ThnMUje","children":[],"key":"Fx2vA7N7Vz"}],"key":"s4mBCivSWi"}],"key":"aBY7GWSktR"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Quality Control using DR","url":"/notebooks/baltrad/baltrad-short-course/baltrad-d