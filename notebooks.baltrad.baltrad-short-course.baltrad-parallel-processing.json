g.Pool(\n        procs\n    )  # Pool of processors. Defaults to all available logical cores\n\n    results = []\n    # chunksize=1 means feed a process a new job as soon as the process is idle.\n    # In our case, this restricts the queue to one \"dispatcher\" which is faster.\n    r = pool.map_async(generate, fstrs, chunksize=1, callback=results.append)\n    r.wait()\n\n    return results[0]","key":"KHG0wbBXPF"},{"type":"outputs","id":"ncmiMyOqxPSwCms7T-_Qm","children":[],"key":"tOpHq4i39w"}],"key":"oGr6doCxxE"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"Feed the monster, asynchronously!","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"key":"yrrAhShhLe"}],"identifier":"feed-the-monster-asynchronously","label":"Feed the monster, asynchronously!","html_id":"feed-the-monster-asynchronously","implicit":true,"key":"ydOgIoXVg1"}],"key":"TAhLacYfDC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"before = time.time()\nofstrs = multi_generate(ifstrs)\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"S7tuqoRFip"},{"type":"outputs","id":"B05pE_1y7dQiGgccvB2Zp","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Processing time: 2.51 seconds\n"},"key":"FNGAUePDe4"}],"key":"iMssqAtZ5k"}],"key":"vxPPqACrST"},{"type":"block","children":[],"key":"OqqHgikueo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"NsKPdAzHET"},{"type":"outputs","id":"tAnwhlWpGyIvcv5Xe9K0l","children":[],"key":"G3h6SyGmCi"}],"key":"iD0jMsbpIB"}],"key":"APrug5W1wP"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Quality Control using DR","url":"/notebooks/baltrad/baltrad-short-course/baltrad-d