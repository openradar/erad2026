it":true,"key":"mARZFsPKjK"}],"key":"KUuzeLUohy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport urllib.request\nfrom pathlib import Path\n\n# Set the URL for the cloud\nURL = \"https://js2.jetstream-cloud.org:8001/\"\npath = \"pythia/radar/erad2024/baltrad/baltrad_short_course/\"\n!mkdir -p data\nfiles = [\n    \"seang.h5\",\n    \"searl.h5\",\n    \"sease.h5\",\n    \"sehud.h5\",\n    \"sekir.h5\",\n    \"sekkr.h5\",\n    \"selek.h5\",\n    \"selul.h5\",\n    \"seosu.h5\",\n    \"sevar.h5\",\n    \"sevil.h5\",\n]\nfor file in files:\n    file0 = os.path.join(path, file)\n    name = os.path.join(\"data\", Path(file).name)\n    if not os.path.exists(name):\n        print(f\"downloading, {name}\")\n        urllib.request.urlretrieve(\n            f\"{URL}{file0}\", os.path.join(\"data\", Path(file).name)\n        )","key":"TKbSxFBdUE"},{"type":"outputs","id":"V0U12829wwHrKGCS7MZnh","children":[],"key":"a5HdzjiGNP"}],"key":"RKbkULU6Q0"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Verify from Python the number of CPU cores at our disposal","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"cpSlIQBiWs"}],"identifier":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","label":"Verify from Python the number of CPU cores at our disposal","html_id":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","implicit":true,"key":"dy58qYzGq8"}],"key":"ZYvMgsbpFY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import multiprocessing\n\nprint(\"We have %i cores to play with!\" % multiprocessing.cpu_count())","key":"PITm0bcGQn"},{"type":"outputs","id":"9D2U8iivNekIVZZGZr6w_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"We have 4 cores to play with!\n"},"key":"Zd0Q4C8sPV"}],"key":"W8gEhuKoq6"}],"key":"DIbIwSWilz"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Yay! Now we’re going to set up some rudimentary functionality that will allow us to distribute a processing load among our cores.","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"WU3Nqo32vF"}],"key":"yn64W7Jigi"}],"key":"YafKXfFsp2"},{"type":"block","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"Define a generator","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"RdXa4Sbe61"}],"identifier":"define-a-generator","label":"Define a generator","html_id":"define-a-generator","implicit":true,"key":"oA75HYVkmH"}],"key":"COCyxVBDL3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport _raveio, odc_polarQC\n\n# Specify the processing chain\nodc_polarQC.algorithm_ids = [\n    \"ropo\",\n    \"beamb\",\n    \"radvol-att\",\n    \"radvol-broad\",\n    \"rave-overshooting\",\n    \"qi-total\",\n]\n\n\n# Run processing chain on a single file. Return an output file string.\ndef generate(file_string):\n    rio = _raveio.open(file_string)\n\n    pvol = rio.object\n    pvol = odc_polarQC.QC(pvol)\n    rio.object = pvol\n\n    # Derive an output file name\n    path, fstr = os.path.split(file_string)\n    ofstr = os.path.join(path, \"qc_\" + fstr)\n\n    rio.save(ofstr)\n    return ofstr","key":"Zh62leL6Xq"},{"type":"outputs","id":"ObPQNzvf93vT-GtlexQt4","children":[],"key":"HMwPIoLxQj"}],"key":"tT9KqSPIRt"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Feed the generator, sequentially","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"h9mXKItS3w"}],"identifier":"feed-the-generator-sequentially","label":"Feed the generator, sequentially","html_id":"feed-the-generator-sequentially","implicit":true,"key":"k7MpnqzTqH"}],"key":"B3YDNTF2C5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import glob, time\n\nifstrs = glob.glob(\"data/se*.h5\")\nbefore = time.time()\nfor fstr in ifstrs:\n    print(fstr, generate(fstr))\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"KXxahBVMwE"},{"type":"outputs","id":"I2Zu2F-ZTkywzhGTKam2O","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevil.h5 data/qc_sevil.h5\n"},"key":"pr0Efg5uw1"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekir.h5 data/qc_sekir.h5\n"},"key":"IV9L2Y4JTS"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sease.h5 data/qc_sease.h5\n"},"key":"jKmONqxtET"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/searl.h5 data/qc_searl.h5\n"},"key":"vXo1Wt1l4w"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selek.h5 data/qc_selek.h5\n"},"key":"auN03RkzPX"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevar.h5 data/qc_sevar.h5\n"},"key":"dTi1Kpmhjl"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sehud.h5 data/qc_sehud.h5\n"},"key":"KkknPTzPZz"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seosu.h5 data/qc_seosu.h5\n"},"key":"wT1LvxdfVC"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seang.h5 data/qc_seang.h5\n"},"key":"AiyzthNNyM"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekkr.h5 data/qc_sekkr.h5\n"},"key":"szGKYg81tQ"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selul.h5 data/qc_selul.h5\nProcessing time: 5.39 seconds\n"},"key":"b3ty0EqjwR"}],"key":"hvaZWcX6jH"}],"key":"JKJ88G6vZe"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"text","value":"Mental note: repeat once!","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"key":"Yy6AGVMCCZ"}],"key":"RgMLWFV8Ly"}],"key":"tFZmqFMqxS"},{"type":"block","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"Multiprocess the generator","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"key":"Rm5ZfJvDKM"}],"identifier":"multiprocess-the-generator","label":"Multiprocess the generator","html_id":"multiprocess-the-generator","implicit":true,"key":"nId8i0AFIt"}],"key":"V7JPmAKz6q"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Both input and output are a list of file strings\ndef multi_generate(fstrs, procs=None):\n    pool = multiprocessing.Pool(\n        procs\n    )  # Pool of processors. Defaults to all available logical cores\n\n    results = []\n    # chunksize=1 means feed a process a new job as soon as the process is idle.\n    # In our case, this restricts the queue to one \"dispatcher\" which is faster.\n    r = pool.map_async(generate, fstrs, chunksize=1, callback=results.append)\n    r.wait()\n\n    return results[0]","key":"hRAJkQaEkE"},{"type":"outputs","id":"koocxSwD_uNq8_TmucY4R","children":[],"key":"WPECg6y9WG"}],"key":"HJMdvJYy8X"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"Feed the monster, asynchronously!","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"key":"DYcoCaY3s5"}],"identifier":"feed-the-monster-asynchronously","label":"Feed the monster, asynchronously!","html_id":"feed-the-monster-asynchronously","implicit":true,"key":"TGleVNWU4O"}],"key":"Gwqx8XiLQR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"before = time.time()\nofstrs = multi_generate(ifstrs)\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"aC8wTLpw49"},{"type":"outputs","id":"0_4pzM2YbcpR0-BteVerq","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Processing time: 2.49 seconds\n"},"key":"hoTs1liuor"}],"key":"ucabyvSXCp"}],"key":"mNEszdKttr"},{"type":"block","children":[],"key":"zTZZmDth3T"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"f6eUh23gjS"},{"type":"outputs","id":"FnKeZODIym1QJoVWLG0V8","children":[],"key":"h1uvaL1VnB"}],"key":"wc96oOlKEz"}],"key":"YXmWwTybPY"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Quality Control using DR","url":"/notebooks/baltrad/baltrad-short-course/baltrad-drqc","group":"BALTRAD"},"next":{"title":"Compositing","url":"/notebooks/baltrad/baltrad-short-course/baltrad-compositing","group":"BALTRAD"}}},"domain":"http://localhost:3000"}